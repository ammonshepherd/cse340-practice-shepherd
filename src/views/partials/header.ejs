<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
    <%- renderStyles() %>
    <%- renderScripts() %>
    <% if (NODE_ENV.includes('dev')) { %>
        <script>
            // Get the current hostname and port from the browser
            const host = window.location.hostname;
            const currentPort = window.location.port;

            // Calculate WebSocket port (current port +1)
            const wsPort = currentPort ? (parseInt(currentPort) + 1) : 3001;

            // Create WebSocket connection using dynamic hostname and port
            const ws = new WebSocket(`ws://${host}:${wsPort}`);
            ws.onclose = () => {
                setTimeout(() => location.reload(), 2000);
            };
        </script>
    <% } %>
</head>
<body>
    
    <header>
        <nav>
            <!-- Always visible links -->
            <a href="/">Home</a>
            <a href="/about">About</a>
            <a href="/catalog">Course Catalog</a>
            <a href="/faculty">Faculty Directory</a>
            <a href="/contact">Contact</a>
            <a href="/demo">Middleware Demo</a>

            <% if (isLoggedIn) { %>
                <!-- Only visible when logged in-->
                <a href="/dashboard">Dashboard</a>
                <a href="/register/list">All Users</a>
                <a href="/contact/responses">Contact Responses</a>
                <a href="/logout">Logout</a>
            <% } %>

            <% if (!isLoggedIn) { %>
                <!-- Only visible when NOT logged in-->
                <a href="/login">Login</a>
                <a href="/register">Register</a>
            <% } %>
        </nav>
    </header>

    <main>