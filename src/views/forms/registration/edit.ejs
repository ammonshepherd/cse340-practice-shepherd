<%- include('../../partials/header') %>

    <h1><%= title %></h1>
    <div class="users-list">
        <div class="user-card">
            <form method="POST" class="user-details" action="/register/<%= user.id %>/edit">
                <div class="detail-item">
                    <label class="label" for="name">Name:</label>
                    <input type="text" class="value" id="name" name="name" value="<%= user.name %>" required>
                </div>

                <div class="detail-item">
                    <label class="label" for="email">Email:</label>
                    <input type="email" class="value" id="email" name="email" value="<%= user.email %>" required>
                </div>

                <div class="detail-item">
                    <button type="submit">Update Account</button>
                </div>
                <div class="detail-item">
                    <a href="/register/list">Cancel</a>
                </div>
            </form>
        </div>
    </div>

<%- include('../../partials/footer') %>